{
  "properties": [
    {
      "name": "app.security.jwt.issuer",
      "type": "java.lang.String",
      "description": "JWT issuer."
    },
    {
      "name": "app.security.jwt.secret",
      "type": "java.lang.String",
      "description": "JWT signing secret."
    },
    {
      "name": "app.security.jwt.expire-minutes",
      "type": "java.lang.Integer",
      "description": "JWT expiration time in minutes."
    },
    {
      "name": "app.bootstrap.admin-username",
      "type": "java.lang.String",
      "description": "Default bootstrap admin username."
    },
    {
      "name": "app.bootstrap.admin-password",
      "type": "java.lang.String",
      "description": "Default bootstrap admin password."
    },
    {
      "name": "app.bootstrap.reset-admin-password-on-start",
      "type": "java.lang.Boolean",
      "description": "Whether to reset bootstrap admin password on startup."
    }
  ]
}
