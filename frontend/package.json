{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.6.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean:vite": "node -e \"try{require('node:fs').rmSync('node_modules/.vite',{recursive:true,force:true})}catch(e){}\"",
    "dev": "vite",
    "dev:force": "vite --force",
    "dev:recover": "npm run clean:vite && vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "@paper-design/shaders-react": "^0.0.72",
    "axios": "^1.13.6",
    "element-plus": "^2.13.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "typescript": "~5.9.3",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.5"
  }
}
